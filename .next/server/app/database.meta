{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/database/layout,_N_T_/database/page,_N_T_/database"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/database/__PAGE__",
    "/database",
    "/_index",
    "/_head"
  ]
}